#!/usr/bin/env python3
"""
Production Environment Configuration
===================================
Template for production environment variables.
Copy to .env and customize for your environment.
"""

# Environment Configuration
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Database Configuration (PostgreSQL recommended for production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wallet_recovery
DB_USER=wallet_user
DB_PASSWORD=
DB_SSL_MODE=require
DB_MAX_CONNECTIONS=20

# Scanner Configuration
SCANNER_MAX_THREADS=10
SCANNER_API_TIMEOUT=5
SCANNER_RATE_LIMIT_BUFFER=0.2
SCANNER_BATCH_SIZE=1000
SCANNER_PROGRESS_INTERVAL=100
SCANNER_MAX_CONCURRENT=15

# Security Settings
ENCRYPT_PRIVATE_KEYS=true
LOG_PRIVATE_KEYS=false
MAX_LOG_SIZE=104857600
BACKUP_RESULTS=true
SECURE_DELETE=true

# Directory Configuration
DATA_DIR=./data
RESULTS_DIR=./results
LOGS_DIR=./logs
BACKUP_DIR=./backup

# Bitcoin API Configuration
BLOCKSTREAM_ENABLED=true
BLOCKSTREAM_RATE_LIMIT=10
BLOCKSTREAM_TIMEOUT=5

BLOCKCYPHER_ENABLED=true
BLOCKCYPHER_RATE_LIMIT=5
BLOCKCYPHER_TIMEOUT=5
BLOCKCYPHER_API_KEY=

BLOCKCHAIN_INFO_ENABLED=false
BLOCKCHAIN_INFO_RATE_LIMIT=1
BLOCKCHAIN_INFO_TIMEOUT=10

# Ethereum API Configuration (optional)
ETHERSCAN_ENABLED=false
ETHERSCAN_RATE_LIMIT=5
ETHERSCAN_TIMEOUT=5
ETHERSCAN_API_KEY=

INFURA_ENABLED=false
INFURA_RATE_LIMIT=10
INFURA_TIMEOUT=5
INFURA_PROJECT_ID=

# Monitoring and Alerting (optional)
MONITORING_ENABLED=false
WEBHOOK_URL=
ALERT_THRESHOLD=1000
EMAIL_ALERTS=false
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
ALERT_RECIPIENTS=

# Performance Tuning
MEMORY_LIMIT=2048
CPU_LIMIT=4
PROCESS_TIMEOUT=3600
MAX_FILE_SIZE=1073741824

# Production Safety
RATE_LIMIT_GLOBAL=100
MAX_DAILY_REQUESTS=100000
AUTO_BACKUP_INTERVAL=3600
HEALTH_CHECK_INTERVAL=300
