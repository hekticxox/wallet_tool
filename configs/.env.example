# Database Environment Configuration
# =================================
# Copy this to .env and customize for your environment

# Database Connection
DATABASE_URL=postgresql://wallet_user:your_secure_password@localhost:5432/wallet_tool
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wallet_tool
DB_USER=wallet_user
DB_PASSWORD=your_secure_password

# Connection Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Performance Settings
DB_ECHO=false
DB_ECHO_POOL=false
DB_STATEMENT_TIMEOUT=30

# Environment
ENVIRONMENT=production
LOG_LEVEL=INFO

# Security
SECRET_KEY=your_secret_key_here_change_this
ENCRYPTION_KEY=your_encryption_key_32_chars_min

# Monitoring
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=60
PROMETHEUS_PORT=9090

# File Storage
SCAN_RESULTS_PATH=/home/admin/wallet_tool/scan_results
LOG_PATH=/home/admin/wallet_tool/logs
BACKUP_PATH=/home/admin/wallet_tool/backups

# Scanner Settings
DEFAULT_MAX_FILES=1000
DEFAULT_SCAN_TIMEOUT=3600
PARALLEL_WORKERS=8

