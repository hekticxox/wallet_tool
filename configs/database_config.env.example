# Database Configuration for Wallet Tool
# =====================================
# Copy this file to .env and customize for your environment

# Database Type: postgresql, sqlite, mysql
DB_TYPE=postgresql

# Connection Settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wallet_tool
DB_USER=wallet_user
DB_PASSWORD=your_secure_password_here

# Database Schema and Naming
DB_SCHEMA=public
DB_TABLE_PREFIX=wallet_

# Connection Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# SSL Configuration
DB_SSL_MODE=prefer
# DB_SSL_CERT=/path/to/client-cert.pem
# DB_SSL_KEY=/path/to/client-key.pem  
# DB_SSL_CA=/path/to/ca-cert.pem

# Application Settings
DB_AUTO_MIGRATE=true
DB_CONNECTION_TIMEOUT=30
DB_QUERY_TIMEOUT=300

# Development Settings (set to false in production)
DB_ECHO_SQL=false
DB_DEBUG_MODE=false

# For SQLite (alternative to PostgreSQL)
# DB_TYPE=sqlite
# DB_NAME=wallet_tool.db

# For MySQL (alternative to PostgreSQL)  
# DB_TYPE=mysql
# DB_PORT=3306
# DB_NAME=wallet_tool
